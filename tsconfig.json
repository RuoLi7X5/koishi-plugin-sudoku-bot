{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "strict": true,
    "target": "es2022",
    "module": "commonjs",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib"]
}
