{
  "name": "koishi-plugin-sudoku-bot",
  "description": "生成数独题目发推题目，统计玩家答题情况，奖励积分",
  "version": "0.0.2",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "files": [
    "lib",
    "dist"
  ],
  "license": "MIT",
  "keywords": [
    "chatbot",
    "koishi",
    "plugin"
  ],
  "scripts": {
    "build": "tsc && esbuild src/index.ts --bundle --platform=node --target=es2020 --external:koishi --external:canvas --external:sudoku --outfile=lib/index.js --format=cjs",
    "build:dev": "yarn build"
  },
  "koishi": {
    "description": {
      "zh": "数独答题游戏插件，支持积分系统、成就系统、排行榜等功能"
    },
    "service": {
      "required": ["database"]
    }
  },
  "peerDependencies": {
    "koishi": "^4.18.7"
  },
  "dependencies": {
    "canvas": "^3.2.1",
    "sudoku": "^0.0.3"
  },
  "devDependencies": {
    "esbuild": "^0.23.0",
    "typescript": "^5.0.0"
  }
}
